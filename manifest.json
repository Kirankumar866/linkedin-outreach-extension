{
  "manifest_version": 3,
  "name": "LinkedIn Outreach Assistant",
  "version": "1.0.0",
  "description": "Scrape LinkedIn profiles, generate personalized outreach messages, and send emails — all in one click.",
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "scripting"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.send"
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/profile-scraper.js", "content/job-scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.hunter.io/*",
    "https://www.googleapis.com/*"
  ]
}
